# Supabase — required for a real shared Reef Gallery (all users see all posts)

# Create a free project at https://supabase.com → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

SUPABASE_SERVICE_ROLE_KEY=your_service_role_key



# App URL (used for Stripe redirect URLs)

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Demo teacher dashboard — full /teacher access without Stripe (auto-on if Stripe keys missing)
SCHOOL_DEMO_MODE=true

# Stripe — School Chapter $49/month subscription

# Dashboard: https://dashboard.stripe.com → Products → create recurring $49/mo price

STRIPE_SECRET_KEY=sk_test_...

STRIPE_SCHOOL_PRICE_ID=price_...

STRIPE_WEBHOOK_SECRET=whsec_...



# Optional: priority support inbox for School Chapter teachers

NEXT_PUBLIC_SCHOOL_SUPPORT_EMAIL=schools@corallookout.org

# ── Hackathon mode (swap name/track per event) ───────────────────────────────
NEXT_PUBLIC_HACKATHON_MODE=true
NEXT_PUBLIC_HACKATHON_NAME=Your Hackathon 2026
NEXT_PUBLIC_HACKATHON_TRACK=Climate · AI · Education
NEXT_PUBLIC_HACKATHON_TAGLINE=Student-driven reef monitoring — scan, map, learn, and compete.
NEXT_PUBLIC_HACKATHON_TEAM=Your Team Name
# NEXT_PUBLIC_HACKATHON_GITHUB=https://github.com/you/coral-lookout
# NEXT_PUBLIC_HACKATHON_DEVPOST=https://devpost.com/...
# NEXT_PUBLIC_HACKATHON_VIDEO=https://youtube.com/...

