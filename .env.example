# Supabase — required for a real shared Reef Gallery (all users see all posts)

# Create a free project at https://supabase.com → Settings → API
# Project URL must resolve — run: npm run check:gallery

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

SUPABASE_SERVICE_ROLE_KEY=your_service_role_key



# App URL (used for Stripe redirect URLs)

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Demo teacher dashboard — full /teacher access without Stripe (auto-on if Stripe keys missing)
SCHOOL_DEMO_MODE=true

# Stripe — School Chapter $49/month subscription

# Dashboard: https://dashboard.stripe.com → Products → create recurring $49/mo price

STRIPE_SECRET_KEY=sk_test_...

STRIPE_SCHOOL_PRICE_ID=price_...

STRIPE_WEBHOOK_SECRET=whsec_...



# Optional: priority support inbox for School Chapter teachers

NEXT_PUBLIC_SCHOOL_SUPPORT_EMAIL=schools@corallookout.org

# Optional: Reef Academy admin dashboard (/admin/academy)
ADMIN_SECRET=your_admin_secret_here

# Direct Postgres URI for one-time academy table setup (npm run setup:academy)
# Supabase → Project Settings → Database → Connection string (URI)
# SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

NEXT_PUBLIC_HACKATHON_MODE=false

# ── AI vision — reef detection (pipeline validate step) ───────────────────────
# Default: local CLIP (no Ollama, no API key, ~2–5s)
AI_VISION_PROVIDER=local
# AI_VISION_MAX_EDGE=384

# Cloud upgrades (optional, faster + smarter):
# GEMINI_API_KEY=your_gemini_api_key
# AI_VISION_PROVIDER=gemini
# OPENAI_API_KEY=sk-...
# HF_TOKEN=hf_...

# Local Ollama (optional, only if AI_VISION_PROVIDER=ollama):
# OLLAMA_VISION_MODEL=llava

# ── Weights & Biases — coral-saving pipeline traces ───────────────────────────
# Get API key: https://wandb.ai/authorize
WANDB_API_KEY=your_wandb_api_key
WANDB_PROJECT=your-team/coral-saving-pipeline
# WANDB_ENTITY=your-team

